# Keep repository text stable across Windows, Linux, macOS, and mobile build hosts.
* text=auto eol=lf

# Binary assets must never receive line-ending conversion.
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ogg binary
*.wav binary
*.ttf binary
*.otf binary
*.zip binary
*.pck binary
*.apk binary
*.aab binary
*.ipa binary
*.exe binary
