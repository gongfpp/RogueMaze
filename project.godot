; Engine configuration file.
; Edit through Godot when possible; keep project-wide defaults reviewable here.

config_version=5

[application]

config/name="RogueMaze"
config/description="Build the road before the runner reaches the edge."
config/version="0.4.0"
config/icon="res://assets/art/icons/roguemaze-app-icon-v1.png"
run/main_scene="res://game/presentation/main.tscn"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/size/window_width_override=405
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/handheld/orientation=1

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/default_filters/use_nearest_mipmap_filter=false

[input]

rotate_card={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":82,"unicode":114)]
}
pause_game={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":32,"unicode":32)]
}
select_card_1={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":49,"unicode":49)]
}
select_card_2={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":50,"unicode":50)]
}
select_card_3={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":51,"unicode":51)]
}
select_card_4={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":52,"unicode":52)]
}
